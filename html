<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biografi | Ni Wayan Lina Valentine, S.Pd</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>

        :root {
            --primary-sage: #8da399;
            --primary-brown: #b8937e;
            --cream: #f9f6f2;
            --beige: #f1ede4;
            --white: #ffffff;
            --dark: #2d3436;
            --text-gray: #636e72;
            --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.05);
            --shadow-medium: 0 15px 35px rgba(141, 163, 153, 0.15);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            outline: none;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--cream);
            color: var(--dark);
            line-height: 1.7;
            overflow-x: hidden;
        }

        h1, h2, h3 {
            font-weight: 700;
            color: var(--dark);
        }

        a {
            text-decoration: none;
            transition: var(--transition);
        }

        ul {
            list-style: none;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .btn {
            padding: 12px 30px;
            border-radius: 50px;
            font-weight: 500;
            display: inline-block;
            cursor: pointer;
            border: none;
            transition: var(--transition);
        }

        .btn-primary {
            background-color: var(--primary-sage);
            color: white;
            box-shadow: 0 8px 20px rgba(141, 163, 153, 0.3);
        }

        .btn-primary:hover {
            background-color: var(--primary-brown);
            transform: translateY(-3px);
            box-shadow: 0 12px 25px rgba(184, 147, 126, 0.4);
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 1000;
            padding: 25px 0;
            transition: var(--transition);
        }

        nav.scrolled {
            background: rgba(255, 255, 255, 0.95);
            padding: 15px 0;
            box-shadow: var(--shadow-soft);
            backdrop-filter: blur(10px);
        }

        nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary-sage);
            letter-spacing: 0.5px;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            color: var(--text-gray);
            font-weight: 500;
            font-size: 0.95rem;
        }

        .nav-links a:hover {
            color: var(--primary-sage);
        }

        .nav-links a.active {
            color: var(--primary-sage);
        }

        .mobile-toggle {
            display: none;
            font-size: 1.5rem;
            cursor: pointer;
        }

        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            background: linear-gradient(135deg, var(--beige) 0%, var(--cream) 100%);
            position: relative;
            padding-top: 80px;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            align-items: center;
            gap: 50px;
        }

        .hero-text h1 {
            font-size: 3.5rem;
            line-height: 1.2;
            margin-bottom: 15px;
        }

        .hero-text .subtitle {
            font-size: 1.5rem;
            color: var(--primary-brown);
            font-weight: 500;
            margin-bottom: 25px;
            display: block;
        }

        .hero-text p {
            color: var(--text-gray);
            font-size: 1.1rem;
            max-width: 500px;
            margin-bottom: 35px;
        }

        .hero-img {
            position: relative;
            display: flex;
            justify-content: center;
        }

        .hero-img .blob {
            width: 400px;
            height: 400px;
            background-color: var(--primary-sage);
            border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
            animation: blobAnimate 8s ease-in-out infinite;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 10px solid var(--white);
        }

        @keyframes blobAnimate {
            0% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
            50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
            100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
        }

        .hero-img img {
            width: 110%;
            height: 110%;
            object-fit: cover;
        }

        .section-padding {
            padding: 100px 0;
            overflow: hidden;
        }

        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title span {
            color: var(--primary-brown);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
            font-size: 0.85rem;
        }

        .section-title h2 {
            font-size: 2.5rem;
            margin-top: 10px;
        }

        .about-grid-clean {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: center;
        }

        .about-image-wrapper {
            position: relative;
            padding: 20px;
        }

        .about-main-img {
            width: 100%;
            border-radius: 25px;
            box-shadow: var(--shadow-medium);
            position: relative;
            z-index: 2;
            display: block;
        }

        .about-image-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: var(--primary-sage);
            border-radius: 25px;
            opacity: 0.1;
            z-index: 1;
        }

        .about-text-clean h3 {
            font-size: 2rem;
            color: var(--primary-sage);
            margin-bottom: 20px;
        }

        .about-text-clean p {
            color: var(--text-gray);
            margin-bottom: 30px;
            text-align: justify;
        }

        .info-grid-simple {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .info-card-simple {
            background: var(--white);
            padding: 20px;
            border-radius: 15px;
            box-shadow: var(--shadow-soft);
            display: flex;
            align-items: center;
            gap: 15px;
            transition: var(--transition);
        }

        .info-card-simple:hover {
            transform: translateY(-5px);
            background: var(--primary-sage);
        }

        .info-card-simple:hover i, 
        .info-card-simple:hover h5, 
        .info-card-simple:hover span {
            color: white;
        }

        .info-card-simple i {
            font-size: 1.5rem;
            color: var(--primary-brown);
        }

        .info-card-simple h5 {
            font-size: 0.8rem;
            color: var(--text-gray);
            margin: 0;
            font-weight: 500;
        }

        .info-card-simple span {
            font-size: 0.95rem;
            font-weight: 700;
            display: block;
        }

        @media (max-width: 992px) {
            .about-grid-clean {
                grid-template-columns: 1fr;
                text-align: center;
            }
            .about-image-wrapper {
                max-width: 500px;
                margin: 0 auto;
            }
            .info-grid-simple {
                text-align: left;
            }
        }

        .timeline {
            position: relative;
            max-width: 900px;
            margin: 0 auto;
        }

        .timeline::after {
            content: '';
            position: absolute;
            width: 2px;
            background: var(--primary-sage);
            top: 0;
            bottom: 0;
            left: 50%;
            margin-left: -1px;
            opacity: 0.3;
        }

        .timeline-item {
            padding: 10px 40px;
            position: relative;
            width: 50%;
        }

        .timeline-item::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            right: -10px;
            background-color: var(--white);
            border: 4px solid var(--primary-brown);
            top: 15px;
            border-radius: 50%;
            z-index: 1;
        }

        .left { left: 0; }
        .right { left: 50%; }

        .right::after { left: -10px; }

        .timeline-content {
            padding: 30px;
            background-color: var(--white);
            border-radius: 20px;
            box-shadow: var(--shadow-soft);
            transition: var(--transition);
        }

        .timeline-content:hover {
            transform: scale(1.03);
            box-shadow: var(--shadow-medium);
        }

        .timeline-content h4 {
            color: var(--primary-sage);
            margin-bottom: 5px;
        }

        .exp-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }

        .exp-card {
            background: var(--white);
            padding: 40px 30px;
            border-radius: 20px;
            text-align: center;
            transition: var(--transition);
            box-shadow: var(--shadow-soft);
        }

        .exp-card:hover {
            transform: translateY(-10px);
            box-shadow: var(--shadow-medium);
        }

        .exp-card i {
            font-size: 2.5rem;
            color: var(--primary-sage);
            margin-bottom: 20px;
        }

        .exp-card h4 {
            margin-bottom: 15px;
        }

        .motivasi {
            background-color: var(--primary-sage);
            color: white;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .motivasi-content {
            max-width: 800px;
            margin: 0 auto;
            position: relative;
            z-index: 2;
        }

        .motivasi h2 {
            color: white;
            font-size: 2.2rem;
            font-style: italic;
            line-height: 1.6;
        }

        .motivasi .quote-icon {
            font-size: 4rem;
            opacity: 0.2;
            margin-bottom: 20px;
        }

        .motivasi {
            background: linear-gradient(135deg, var(--primary-sage) 0%, #6b8e6a 50%, var(--primary-brown) 100%);
            position: relative;
            overflow: hidden;
        }

        .motivasi::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 20% 80%, rgba(255,255,255,0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15) 0%, transparent 50%),
                radial-gradient(circle at 40% 40%, rgba(255,255,255,0.05) 0%, transparent 50%);
            animation: motivasiFloat 20s ease-in-out infinite;
            z-index: 1;
        }

        @keyframes motivasiFloat {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33% { transform: translateY(-20px) rotate(1deg); }
            66% { transform: translateY(-10px) rotate(-1deg); }
        }

        .motivasi-content {
            position: relative;
            z-index: 2;
            text-align: center;
            padding: 60px 20px;
        }

        .motivasi h2 {
            font-size: 2.5rem;
            line-height: 1.4;
            position: relative;
            display: inline-block;
            background: linear-gradient(45deg, white 0%, #f0f8f0 50%, white 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: textGlow 3s ease-in-out infinite alternate;
        }

        @keyframes textGlow {
            0% { filter: drop-shadow(0 0 10px rgba(255,255,255,0.5)); }
            100% { filter: drop-shadow(0 0 20px rgba(255,255,255,0.8)); }
        }

        .motivasi .quote-icon {
            font-size: 5rem;
            opacity: 0.3;
            margin-bottom: 30px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-10px); }
            60% { transform: translateY(-5px); }
        }

        .motivasi p {
            font-size: 1.1rem;
            letter-spacing: 1px;
        }

        .siswa-section {
            background-color: var(--beige);
            overflow: hidden;
        }

        .carousel-wrapper {
            position: relative;
            height: 550px;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            perspective: 1200px; 
        }

        .carousel-item {
            position: absolute;
            width: 300px;
            height: 420px;
            background: var(--white);
            border-radius: 25px;
            padding: 10px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            user-select: none;
            opacity: 0;
            pointer-events: none;
        }

        .carousel-item.active {
            opacity: 1;
            transform: translate3d(0, 0, 100px) rotateY(0deg) scale(1.1);
            z-index: 10;
            pointer-events: auto;
            border: 2px solid var(--primary-sage);
            box-shadow: 0 25px 50px rgba(141, 163, 153, 0.3);
        }

        .carousel-item.prev {
            opacity: 0.7;
            transform: translate3d(-320px, 0, 0) rotateY(35deg) scale(0.85);
            z-index: 5;
        }

        .carousel-item.next {
            opacity: 0.7;
            transform: translate3d(320px, 0, 0) rotateY(-35deg) scale(0.85);
            z-index: 5;
        }

        .carousel-item.far-prev {
            opacity: 0;
            transform: translate3d(-500px, 0, -100px) rotateY(45deg) scale(0.7);
        }

        .carousel-item.far-next {
            opacity: 0;
            transform: translate3d(500px, 0, -100px) rotateY(-45deg) scale(0.7);
        }

        .student-img {
            width: 150px;
            height: 150px;
            border-radius: 20px;
            background: var(--beige);
            margin-bottom: 25px;
            overflow: hidden;
            border: 5px solid var(--cream);
            transition: var(--transition);
        }

        .student-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .carousel-item:hover .student-img {
            transform: scale(1.05);
            border-color: var(--primary-sage);
        }

        .carousel-item h4 {
            font-size: 1.4rem;
            margin-bottom: 5px;
            color: var(--dark);
        }

        .carousel-item .class-tag {
            background: var(--primary-sage);
            color: white;
            padding: 4px 15px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .carousel-item .role {
            color: var(--primary-brown);
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 10px;
        }

        .carousel-item p {
            font-size: 0.85rem;
            color: var(--text-gray);
        }

        .carousel-controls {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 20px;
        }

        .nav-btn {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background: var(--white);
            border: none;
            cursor: pointer;
            box-shadow: var(--shadow-soft);
            color: var(--primary-sage);
            font-size: 1.2rem;
            transition: var(--transition);
        }

        .nav-btn:hover {
            background: var(--primary-sage);
            color: white;
            transform: scale(1.1);
        }

        footer {
            background: var(--white);
            padding: 50px 0;
            text-align: center;
            border-top: 1px solid var(--beige);
        }

        .footer-socials {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 25px;
        }

        .footer-socials a {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: var(--beige);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary-sage);
            font-size: 1.2rem;
        }

        .footer-socials a:hover {
            background: var(--primary-sage);
            color: white;
            transform: translateY(-5px);
        }

        @media (max-width: 992px) {
            .hero-grid, .about-grid {
                grid-template-columns: 1fr;
                text-align: center;
            }
            .hero-text p, .hero-text h1 {
                margin-left: auto;
                margin-right: auto;
            }
            .hero-img {
                order: -1;
            }
            .timeline::after {
                left: 31px;
            }
            .timeline-item {
                width: 100%;
                padding-left: 70px;
                padding-right: 25px;
            }
            .timeline-item.right {
                left: 0;
            }
            .timeline-item::after {
                left: 21px;
            }
            .carousel-item.next {
                transform: translate3d(180px, 0, -50px) rotateY(-30deg) scale(0.8);
            }
            .carousel-item.prev {
                transform: translate3d(-180px, 0, -50px) rotateY(30deg) scale(0.8);
            }
        }

        @media (max-width: 768px) {
            .nav-links {
                display: none; 
            }
            .hero-text h1 {
                font-size: 2.5rem;
            }
            .carousel-item {
                width: 260px;
            }
            .carousel-item.next, .carousel-item.prev {
                opacity: 0; 
            }
        }

        section {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden; 
        }

        .hero {
            min-height: 100vh !important;
            padding-top: 80px;
            padding-bottom: 80px;
        }

        .section-padding {
            min-height: 100vh;
            padding: 120px 0;
            display: flex;
            align-items: center;
        }

        .timeline {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 0; 
        }

        .exp-grid {
            padding: 20px 0;
        }

        .carousel-wrapper {
            height: 600px; 
            min-height: 600px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            width: 100%;
            height: 100%;
        }

        html {
            scroll-behavior: smooth;
            scroll-padding-top: 100px; 
        }

        @media (max-width: 992px) {
            .timeline {
                padding: 20px 0;
            }
            
            .section-padding {
                padding: 80px 0;
                min-height: 100vh;
            }
        }

        footer {
            min-height: auto !important;
            padding: 50px 0;
        }
    </style>
</head>
<body>

    <nav id="navbar">
        <div class="container">
            <a href="#" class="logo">Biografi Guru.</a>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#tentang">Tentang</a></li>
                <li><a href="#riwayat">Riwayat</a></li>
                <li><a href="#pengalaman">Pengalaman</a></li>
                <li><a href="#motivasi">Motivasi</a></li>
                <li><a href="#siswa">Siswa</a></li>
            </ul>
            <div class="mobile-toggle">
                <i class="fas fa-bars"></i>
            </div>
        </div>
    </nav>

    <section class="hero" id="home">
        <div class="container">
            <div class="hero-grid">
                <div class="hero-text" data-aos="fade-right">
                    <span class="subtitle">Om Swastiastu</span>
                    <h1>Ni Wayan Lina Valentine, S.Pd</h1>
                    <p>Mendedikasikan diri untuk melestarikan budaya dan bahasa melalui pendidikan yang kreatif dan berkarakter.</p>
                    <a href="#tentang" class="btn btn-primary">Kenali Lebih Jauh</a>
                </div>
                <div class="hero-img" data-aos="zoom-in">
                    <div class="blob">

                        <img src="foto/guru2.png" alt="Ni Wayan Lina Valentine">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-padding" id="tentang">
        <div class="container">
            <div class="section-title" data-aos="fade-up">
                <span>Profil Pendidik</span>
                <h2>Ni Wayan Lina Valentine, S.Pd</h2>
            </div>

            <div class="about-grid-clean">

                <div class="about-image-wrapper" data-aos="fade-right">
                    <img src="foto/guru3.jpeg" alt="Lina Valentine" class="about-main-img">
                </div>

                <div class="about-text-clean" data-aos="fade-left">
                    <h3>Mengenal Lebih Dekat</h3>
                    <p>
                        Perjalanan saya di dunia pendidikan dimulai pada tahun 2020. Awalnya, menjadi guru adalah sebuah percobaan yang tidak direncanakan, namun seiring berjalannya waktu, saya menemukan kebahagiaan saat melihat siswa mulai memahami materi dan tumbuh rasa percaya dirinya. Sebagai pengajar Bahasa Bali, saya berkomitmen untuk menjaga warisan budaya melalui cara yang menyenangkan.
                    </p>

                    <div class="info-grid-simple">
                        <div class="info-card-simple">
                            <i class="fas fa-calendar-alt"></i>
                            <div>
                                <h5>Lahir</h5>
                                <span>14 Feb 1998</span>
                            </div>
                        </div>
                        <div class="info-card-simple">
                            <i class="fas fa-music"></i>
                            <div>
                                <h5>Hobi</h5>
                                <span>Musik & Kuliner</span>
                            </div>
                        </div>
                        <div class="info-card-simple">
                            <i class="fas fa-graduation-cap"></i>
                            <div>
                                <h5>Gelar</h5>
                                <span>S.Pd</span>
                            </div>
                        </div>
                        <div class="info-card-simple">
                            <i class="fas fa-school"></i>
                            <div>
                                <h5>Mengajar</h5>
                                <span>Sejak 2020</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <section class="section-padding" id="riwayat" style="background-color: var(--white);">
        <div class="container">
            <div class="section-title" data-aos="fade-up">
                <span>Jejak Langkah</span>
                <h2>Riwayat Pendidikan</h2>
            </div>
            <div class="timeline">
                <div class="timeline-item left" data-aos="fade-right">
                    <div class="timeline-content">
                        <h4>SD 17 Dauh Puri</h4>
                        <p>Pendidikan Dasar Pertama</p>
                    </div>
                </div>
                <div class="timeline-item right" data-aos="fade-left">
                    <div class="timeline-content">
                        <h4>SMP Negeri 4 Denpasar</h4>
                        <p>Pendidikan Menengah Pertama</p>
